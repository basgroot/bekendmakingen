{
    "name": "bekendmakingen",
    "version": "0.1.0",
    "private": true,
    "description": "Bouwmelding.nl — Dutch government publications (vergunningen) on an interactive map.",
    "homepage": "https://bouwmelding.nl/",
    "repository": {
        "type": "git",
        "url": "https://github.com/basgroot/bekendmakingen.git"
    },
    "license": "GPL-3.0-only",
    "engines": {
        "node": ">=18"
    },
    "type": "module",
    "scripts": {
        "prepare": "git config core.hooksPath .githooks",
        "build": "node node_modules/terser/bin/terser map.js -o map.min.js --compress --mangle && node node_modules/clean-css-cli/bin/cleancss map.css -o map.min.css",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "check": "npm run lint && npm run format:check"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "clean-css-cli": "^5.6.3",
        "eslint": "^10.4.0",
        "eslint-plugin-jsdoc": "^63.0.1",
        "globals": "^17.6.0",
        "prettier": "^3.8.3",
        "terser": "^5.48.0"
    }
}
