    given-names: B
    alias: basgroot

version: "0.1.0"
date-released: "2026-04-24"
license: GPL-3.0-only
url: "https://bouwmelding.nl/"
repository-code: "https://github.com/basgroot/bekendmakingen"
keywords:
  - netherlands
  - dutch
  - open-data
  - government
  - permits
  - bekendmakingen
  - vergunningen
  - maps
  - google-maps
  - pwa
  - javascript
