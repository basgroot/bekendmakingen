{
    "tabWidth": 4,
    "semi": true,
    "endOfLine": "lf",
    "singleQuote": false,
    "printWidth": 150,
    "trailingComma": "none",
    "quoteProps": "preserve",
    "experimentalTernaries": true,
    "overrides": [
        {
            "files": ["*.md", "*.yml", "*.yaml"],
            "options": {
                "tabWidth": 2
            }
        }
    ]
}
